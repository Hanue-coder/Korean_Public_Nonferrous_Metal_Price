{
  "name": "RCOA — Korean Metal Price Dashboard",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "postCreateCommand": "pip install requests beautifulsoup4 && npm install -g @anthropic-ai/claude-code",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Dashboard",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
